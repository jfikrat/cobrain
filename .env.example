# Telegram Bot Token (@BotFather'dan al)
TELEGRAM_BOT_TOKEN=

# Anthropic API Key (console.anthropic.com)
ANTHROPIC_API_KEY=

# Telegram User ID (tek kullanıcı - @userinfobot'tan öğren)
MY_TELEGRAM_ID=

# Gemini API Key (ses tanıma için, opsiyonel)
GEMINI_API_KEY=

# İsteğe bağlı ayarlar
MAX_HISTORY=10
AGENT_MODEL=claude-opus-4-6
TRANSCRIPTION_MODEL=gemini-3-flash-preview

# Stem (arka plan ajanı)
# Canonical isimler: STEM_*
# Legacy alias'lar (SENTINEL_*) backward compatibility için desteklenir.
FF_STEM=true
STEM_MODEL=claude-haiku-4-5-20251001
STEM_MAX_TURNS=5
STEM_CONSOLIDATION_THRESHOLD=170000
STEM_MAX_WAKES_PER_HOUR=10

# Web UI
WEB_PORT=3000
ENABLE_WEB_UI=true

# Heartbeat (Living Assistant)
ENABLE_HEARTBEAT_MONITORING=true
HEARTBEAT_LOG_INTERVAL_MS=30000
