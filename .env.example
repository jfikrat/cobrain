# Telegram Bot Token (@BotFather'dan al)
TELEGRAM_BOT_TOKEN=

# Cerebras API Key
CEREBRAS_API_KEY=

# İzin verilen Telegram kullanıcı ID'leri (virgülle ayır)
# Kendi ID'ni öğrenmek için: @userinfobot'a mesaj at
ALLOWED_USER_IDS=

# İsteğe bağlı ayarlar
CEREBRAS_MODEL=gpt-oss-120b
MAX_HISTORY=10
DB_PATH=./data/cobrain.db

# Ses tanıma modeli (varsayılan: gemini-3-flash-preview)
TRANSCRIPTION_MODEL=gemini-3-flash-preview

# Agent modeli (varsayılan: claude-opus-4-20250514)
AGENT_MODEL=claude-opus-4-20250514
