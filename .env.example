# ── Required ──────────────────────────────────────────────

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# Your Telegram User ID (get from @userinfobot on Telegram)
MY_TELEGRAM_ID=

# Anthropic API Key (get from console.anthropic.com)
# Set as env var or in .claude/.credentials — Agent SDK picks it up automatically
ANTHROPIC_API_KEY=

# ── Optional ──────────────────────────────────────────────

# AI Model (default: claude-sonnet-4-6)
# AGENT_MODEL=claude-sonnet-4-6

# Max conversation turns per request (default: 20)
# MAX_AGENT_TURNS=20

# Conversation history length (default: 10)
# MAX_HISTORY=10

# Tool permission mode: strict (ask for everything), smart (ask for dangerous), yolo (auto-approve)
# PERMISSION_MODE=strict

# ── Voice Transcription (optional) ────────────────────────

# Gemini API Key — only needed for voice message transcription
# GEMINI_API_KEY=
# TRANSCRIPTION_MODEL=gemini-3.1-flash-lite-preview

# ── API Server ────────────────────────────────────────────

# REST API port (default: 3000)
# API_PORT=3000

# API authentication key — set this to protect /api/* endpoints
# COBRAIN_API_KEY=

# ── Advanced ──────────────────────────────────────────────

# Data directory (default: ~/.cobrain)
# COBRAIN_BASE_PATH=~/.cobrain

# Autonomous features: BrainLoop, proactive behaviors, reminders (default: true)
# ENABLE_AUTONOMOUS=true

# Heartbeat monitoring (default: true)
# ENABLE_HEARTBEAT_MONITORING=true

# Feature flags
# FF_BRAIN_EVENTS=true
# FF_SESSION_STATE=true
# FF_MEMORY_CONSOLIDATION=true

# BrainLoop tick intervals (ms)
# BRAIN_LOOP_FAST_TICK_MS=5000
# BRAIN_LOOP_SLOW_TICK_MS=300000

# ── MCP Servers (optional) ────────────────────────────────

# Add custom MCP servers by creating ~/.cobrain/mcp-servers.json:
#
# {
#   "filesystem": {
#     "command": "npx",
#     "args": ["-y", "@modelcontextprotocol/server-filesystem", "/home/user/docs"]
#   },
#   "github": {
#     "command": "npx",
#     "args": ["-y", "@modelcontextprotocol/server-github"],
#     "env": { "GITHUB_TOKEN": "ghp_xxx" }
#   }
# }
#
# Any stdio-compatible MCP server works. See: https://modelcontextprotocol.io/servers

# ── Multi-Agent Hub (optional) ────────────────────────────

# Telegram forum group ID — enables multi-agent mode with topic-based agents
# COBRAIN_HUB_ID=

# Log channel ID — autonomous event logs sent here
# LOG_CHANNEL_ID=
