{
  "name": "cobrain",
  "version": "1.0.0",
  "description": "Self-hosted Telegram AI assistant with local memory and autonomous workflows",
  "module": "src/index.ts",
  "type": "module",
  "private": false,
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --hot src/index.ts",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit",
    "migrate": "bun run scripts/migrate-v02.ts",
    "migrate:execute": "bun run scripts/migrate-v02.ts --execute",
    "migrate:rollback": "bun run scripts/migrate-v02.ts --rollback --execute"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.62",
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/generative-ai": "^0.24.1",
    "@grammyjs/runner": "^2.0.3",
    "grammy": "^1.39.3",
    "zod": "^4.3.6"
  }
}
